expression 'Function Department Import' = ```
		let
		    Source = SharePoint.Files("https://stevendouglascorp.sharepoint.com/sites/SDC-PowerBIIntegration/", [ApiVersion = 15]),
		    #"Filtered Rows" = Table.SelectRows(Source, each ([Name] = "Project Planner Data Control.xlsx")),
		    #"Project Planner Data Control xlsx_https://stevendouglascorp sharepoint com/sites/SDC-PowerBIIntegration/Shared Documents/Project Planner V2/Job Hours Report/" = #"Filtered Rows"{[Name="Project Planner Data Control.xlsx",#"Folder Path"="https://stevendouglascorp.sharepoint.com/sites/SDC-PowerBIIntegration/Shared Documents/Project Planner V2/Job Hours Report/"]}[Content],
		    #"Imported Excel Workbook" = Excel.Workbook(#"Project Planner Data Control xlsx_https://stevendouglascorp sharepoint com/sites/SDC-PowerBIIntegration/Shared Documents/Project Planner V2/Job Hours Report/"),
		    Estimates_Sheet = #"Imported Excel Workbook"{[Item="FunctionDepartment",Kind="Table"]}[Data],
		    #"Changed Type" = Table.TransformColumnTypes(Estimates_Sheet,{{"Function Id", type text}}),
		    
		    // Create distinct lists with order assigned - more efficient approach
		    DistinctFunctions = Table.Distinct(Table.SelectColumns(#"Changed Type", {"Function"})),
		    FunctionOrderTable = Table.AddIndexColumn(DistinctFunctions, "Function Order", 1, 1),
		    
		    DistinctFunctionDepartments = Table.Distinct(Table.SelectColumns(#"Changed Type", {"Function Department"})),
		    FunctionDepartmentOrderTable = Table.AddIndexColumn(DistinctFunctionDepartments, "Function Department Order", 1, 1),
		    
		    // Merge these back to the original table
		    MergedWithFunctionOrder = Table.NestedJoin(#"Changed Type", {"Function"}, FunctionOrderTable, {"Function"}, "FunctionOrderTable", JoinKind.LeftOuter),
		    ExpandedFunctionOrder = Table.ExpandTableColumn(MergedWithFunctionOrder, "FunctionOrderTable", {"Function Order"}, {"Function Order"}),
		    
		    MergedWithDepartmentOrder = Table.NestedJoin(ExpandedFunctionOrder, {"Function Department"}, FunctionDepartmentOrderTable, {"Function Department"}, "FunctionDepartmentOrderTable", JoinKind.LeftOuter),
		    Result = Table.ExpandTableColumn(MergedWithDepartmentOrder, "FunctionDepartmentOrderTable", {"Function Department Order"}, {"Function Department Order"})
		in
		    Result
		```
	lineageTag: 8d52dfcd-9fe5-447e-b8b9-60a004bbfa76

