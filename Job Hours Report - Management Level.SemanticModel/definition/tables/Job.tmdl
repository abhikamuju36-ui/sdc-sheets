	column 'Overrun Description' =
			
			switch(
			    true(),
			    and([Is Engineering Overrun] = TRUE(), [Is Shop Overrun] = TRUE()), "Engineering and Shop",
			    [Is Engineering Overrun] = TRUE(), "Engineering",
			    [Is Shop Overrun] = TRUE(), "Shop",
			    "No Overrun"
			)
