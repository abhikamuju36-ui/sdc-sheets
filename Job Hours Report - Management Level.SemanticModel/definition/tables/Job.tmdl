	column 'Effective Close Date' =
			
			// Active jobs: BLANK (always treated as open)
			// Complete jobs with a recorded close date: use that date
			// Complete jobs with no close date: use max valid hours date as a proxy
			IF(
			    'Job'[Job Status] <> "Complete",
			    BLANK(),
			    IF(
			        NOT(ISBLANK('Job'[Complete Date])),
			        'Job'[Complete Date],
			        CALCULATE(
			            MAX('Hours Actual'[Date]),
			            NOT(LEFT('Hours Actual'[Section-Function Code], 2) IN {"98"}),
			            NOT('Hours Actual'[Job Id] IN {"4000","1083","7000","10000"})
			        )
			    )
			)
		dataType: dateTime
		isHidden
		formatString: Short Date
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef0987654321
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Is Complete Date Missing' = 'Job'[Job Status] = "Complete" && ISBLANK('Job'[Complete Date])
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f01234567890
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Is Complete Date Calculated' = 'Job'[Job Status] = "Complete" && ISBLANK('Job'[Complete Date]) && NOT(ISBLANK('Job'[Effective Close Date]))
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: c3d4e5f6-a7b8-9012-cdef-012345678901
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

