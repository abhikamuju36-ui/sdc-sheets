	partition 'Job Employee Hours' = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        FILTER('Hours Actual', 'Hours Actual'[Sub-Section Id] = "80"),
				        Job[Job Id],
				        Job[Job], 
				        Employee[Employee Id], 
				        Employee[Employee Name], 
				        'Date'[Date]
				    ),
				    "Job Display", trim(LEFT(Job[Job], 11)) & " - " & Employee[Employee Name] & " - " & FORMAT([Hours Actual], "0") & " Hrs"
				)
				```

	annotation PBI_Id = fe75fea5bc3c42dd9d95228b5013a655

