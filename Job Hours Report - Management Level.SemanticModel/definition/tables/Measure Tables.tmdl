	measure 'Standard Fees - Monthly Process - Hours Quoted by ETC Period' = ```
			
			VAR CurrentETCPeriodKey = 
			    SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentETCYear = INT(CurrentETCPeriodKey / 100)
			VAR CurrentETCMonth = MOD(CurrentETCPeriodKey, 100)
			
			RETURN
			CALCULATE(
			    SUM('Hours Estimated'[Hours Quoted]),
			    ALL('Date'),
			    FILTER(
			        ALL('Job'),
			        YEAR('Job'[Start Date]) = CurrentETCYear &&
			        MONTH('Job'[Start Date]) = CurrentETCMonth
			    ),
			    FILTER(
			        ALL('Function Hierarchy'),
			        VAR CurrentDepartment = SELECTEDVALUE('Standard Fees'[Department])
			        VAR CurrentBillingGroup = SELECTEDVALUE('Standard Fees'[Billing Group])
			        RETURN
			        SWITCH(
			            TRUE(),
			            
			            -- PM Department
			            CurrentDepartment = "PM",
			                'Function Hierarchy'[Section Function Name] = "PM" &&
			                'Function Hierarchy'[Section Id] = "10",
			            
			            -- Manufacturing Department
			            CurrentDepartment = "Manufacturing",
			                'Function Hierarchy'[Section Function Name] = "Manufacturing" &&
			                'Function Hierarchy'[Section Id] = "10",
			            
			            -- Warranty + Engineering
			            CurrentDepartment = "Warranty" && CurrentBillingGroup = "Engineering",
			                'Function Hierarchy'[Billing Group] = "Engineering" &&
			                'Function Hierarchy'[Section Id] = "70",
			            
			            -- Warranty + Shop
			            CurrentDepartment = "Warranty" && CurrentBillingGroup = "Shop",
			                'Function Hierarchy'[Billing Group] = "Shop" &&
			                'Function Hierarchy'[Section Id] = "70",
			            
			            -- Default: keep all rows
			            FALSE()
			        )
			    )
			)
			```
		formatString: #,0
		lineageTag: 89bc915a-07bd-486e-b904-e5275a507a62

	measure 'Standard Fees - Monthly Process - Hours Actual by ETC Period' = ```
			
			VAR CurrentETCPeriodKey = 
			    SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentETCYear = INT(CurrentETCPeriodKey / 100)
			VAR CurrentETCMonth = MOD(CurrentETCPeriodKey, 100)
			VAR CurrentDepartment = SELECTEDVALUE('Standard Fees'[Department])
			
			RETURN
			
			IF(
			    // PM department always return 0
			    CurrentDepartment IN {"PM"},
			    0,
			    
			    CALCULATE(
			        SUM('Hours Actual'[Hours Actual]),
			        FILTER(
			            ALL('Date'),
			            YEAR('Date'[Date]) = CurrentETCYear &&
			            MONTH('Date'[Date]) = CurrentETCMonth
			        ),
			        FILTER(
			            ALL('Function Hierarchy'),
			            VAR CurrentBillingGroup = SELECTEDVALUE('Standard Fees'[Billing Group])
			            RETURN
			            SWITCH(
			                TRUE(),
			                -- Manufacturing Department
			                CurrentDepartment = "Manufacturing",
			                'Function Hierarchy'[Section Function Name] = "Manufacturing" &&
			                'Function Hierarchy'[Section Id] = "10",
			
			                -- Warranty + Engineering
			                CurrentDepartment = "Warranty" && CurrentBillingGroup = "Engineering",
			                    'Function Hierarchy'[Billing Group] = "Engineering" &&
			                    'Function Hierarchy'[Section Id] = "70",
			                
			                -- Warranty + Shop
			                CurrentDepartment = "Warranty" && CurrentBillingGroup = "Shop",
			                    'Function Hierarchy'[Billing Group] = "Shop" &&
			                    'Function Hierarchy'[Section Id] = "70",
			                
			                -- Default: keep all rows
			                FALSE()
			            )
			        )
			    )
			)
			```
		formatString: #,0
		lineageTag: 0ea41b8f-c2a9-444c-b34e-034acad87778

