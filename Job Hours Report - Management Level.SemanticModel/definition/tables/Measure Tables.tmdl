	measure 'ETC Monthly Process - Prior ETC Cost' =
			
			VAR PriorMonthStart = EOMONTH(TODAY(), -2) + 1
			RETURN
			SUMX(
			    VALUES('Job'[Job Id]),
			    VAR JobStartDate = CALCULATE(MAX('Job'[Start Date]))
			    RETURN
			    IF(
			        NOT(ISBLANK(JobStartDate)) && JobStartDate >= PriorMonthStart,
			        [Part Cost Quoted],
			        [Part Cost Estimated To Complete]
			    )
			)
		lineageTag: f025c090-282c-4fae-84bb-676156fa3f65

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Costs Estimated to Complete' =
			
