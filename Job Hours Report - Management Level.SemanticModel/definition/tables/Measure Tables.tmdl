	measure 'Relative Days' =
			
			VAR minDate = MIN('Date'[Date])
			VAR maxDate = MAX('Date'[Date])
			VAR days = DATEDIFF(MinDate, MaxDate, DAY) + 1
			RETURN
			    days
		formatString: 0
		lineageTag: 0e6db650-70a5-438f-a77c-9cc2c33eb7e1

