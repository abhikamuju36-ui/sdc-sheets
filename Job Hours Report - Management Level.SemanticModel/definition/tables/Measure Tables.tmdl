	measure 'Hours Actual Billable' =
			
			CALCULATE(
			    SUM('Hours Actual'[Hours Actual]),
			    Employee[Employee Department] IN {"Controls Engineering","Machine Building","Machine Wiring","Mechanical Engineering","Manufacturing"},
			    FILTER(
			        'Hours Actual',
			        (
			            (ISBLANK(RELATED('Job'[Effective Close Date])) || 'Hours Actual'[Date] <= RELATED('Job'[Effective Close Date])) &&
			            NOT(LEFT('Hours Actual'[Section-Function Code], 2) IN {"98"}) && //98=Invalid
			            NOT('Hours Actual'[Job Id] IN {"4000","1083","7000","10000"})
			        )
			        ||
			        (
			            NOT(ISBLANK(RELATED('Job'[Effective Close Date]))) && 'Hours Actual'[Date] > RELATED('Job'[Effective Close Date]) &&
			            LEFT('Hours Actual'[Section-Function Code], 2) IN {"70","80","90"} && //70=Warranty, 80=Service, 90=Spare Parts
			            NOT('Hours Actual'[Job Id] IN {"4000","1083","7000","10000"})
			        )
			    )
			)
		formatString: #,0
		lineageTag: 82fa7207-d584-4127-8f25-62fd03407550

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Estimated Remaining Days Shop' =
			
			CALCULATE(
			    DIVIDE([Hours ETC Variance], ([Shop Employees]*[Work Hours Per Day])),
			    KEEPFILTERS('Function Hierarchy'[Billing Group] = "Shop"),
			    KEEPFILTERS(Job[Is Active Job] = TRUE())
			) * 7/5  // Convert from calendar days to workdays
		lineageTag: 77e4dc60-80ee-4b85-8f7d-befb8090044f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Estimated Remaining Days Engineering' =
			
			CALCULATE(
			    DIVIDE([Hours ETC Variance], ([Engineering Employees]*[Work Hours Per Day])),
			    KEEPFILTERS('Function Hierarchy'[Billing Group] = "Engineering"),
			    KEEPFILTERS(Job[Is Active Job] = TRUE())
			) * 7/5  // Convert from calendar days to workdays
		lineageTag: a4eecdda-073e-4b37-8cc4-89f72f2d0aef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

