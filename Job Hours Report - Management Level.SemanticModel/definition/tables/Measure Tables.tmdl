	measure 'Engineering Overtime Hours' =
			
			SUMX(
			    FILTER(
			        SUMMARIZE(
			            FILTER(
			                'Hours Actual',
			                RELATED(Employee[Employee Billing Group]) = "Engineering"
			            ),
			            Employee[Employee Name],
			            'Date'[Date]
			        ),
			        VAR DailyHours = CALCULATE(SUM('Hours Actual'[Hours Actual]))
			        RETURN DailyHours > 8
			    ),
			    VAR DailyHours = CALCULATE(SUM('Hours Actual'[Hours Actual]))
			    RETURN DailyHours - 8
			)
		formatString: #,0
		lineageTag: c1183ac8-454c-4837-a27e-f68d0da9cea8

