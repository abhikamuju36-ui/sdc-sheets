	measure 'Hours Actual Prior Month' =
			
			VAR CurrentPeriodKey = SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentYear = INT(CurrentPeriodKey / 100)
			VAR CurrentMonth = MOD(CurrentPeriodKey, 100)
			VAR PriorYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			VAR PriorMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PriorPeriodKey = PriorYear * 100 + PriorMonth
			RETURN
			SUMX(
			    VALUES('Hours Estimated to Complete History'[Job Id]),
			    VAR CurrentJobId = 'Hours Estimated to Complete History'[Job Id]
			    RETURN
			    CALCULATE(
			        SUM('Hours Actual'[Hours Actual]),
			        'Hours Actual'[Job Id] = CurrentJobId,
			        REMOVEFILTERS('Date'),
			        'Date'[Year Month Id] = PriorPeriodKey
			    )
			)
		formatString: #,0
		lineageTag: b42c4d58-cfc3-4137-9c0f-abea5f2edd7a

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Hours Actual Prior Month, Employee Count' =
			
			VAR CurrentPeriodKey = SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentYear = INT(CurrentPeriodKey / 100)
			VAR CurrentMonth = MOD(CurrentPeriodKey, 100)
			VAR PriorYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			VAR PriorMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PriorPeriodKey = PriorYear * 100 + PriorMonth
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('Hours Actual'[Employee Id]),
			    REMOVEFILTERS('Date'),
			    'Date'[Year Month Id] = PriorPeriodKey
			)
