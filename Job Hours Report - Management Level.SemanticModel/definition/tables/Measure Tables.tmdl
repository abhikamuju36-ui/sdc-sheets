table 'Measure Tables'
	lineageTag: 2d363c8f-3c36-466b-9a1d-ebe8dfdbe90f

	measure 'Hours Actual' =
			
			CALCULATE(sum('Hours Actual'[Hours Actual]))
		formatString: #,0
		lineageTag: 40cb567e-6f96-4ee3-9c39-99a5f4f46205

	measure 'Hours Quoted' =
			
			CALCULATE(
			    SUM('Hours Estimated'[Hours Quoted]),
			    ALL('Date')
			)
		formatString: #,0
		lineageTag: acbd3bd9-4710-4c33-afec-ce45c35f7bd7

	measure 'Hours Quoted Remaining' = [Hours Quoted] - [Hours Actual]
		formatString: #,0
		lineageTag: ea6ef5b6-e4d9-4fd0-9da6-34c3226a5924

	measure 'Is Overrun' = if([Hours Quoted Remaining] < 0,TRUE(),FALSE())
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: d8e80785-f762-4fb2-b9a3-7827b8c37637

	measure 'Job Display' = ```
			
			VAR SelectedJobCount = DISTINCTCOUNT(Job[Job])
			VAR FirstJob = IF(SelectedJobCount = 1, FIRSTNONBLANK(Job[Job], 1), "")
			VAR AllJobsCount = CALCULATE(DISTINCTCOUNT(Job[Job]), REMOVEFILTERS(Job))
			RETURN
			    IF(
			        SelectedJobCount = 1, 
			        FirstJob,  // Show the specific job when exactly one job is selected
			        IF(
			            SelectedJobCount = AllJobsCount,
			            "All Jobs Selected",  // Show "All Jobs" when all jobs are selected
			            "Multiple Jobs Selected"  // Show this text when multiple (but not all) jobs are selected
			        )
			    )
			```
		displayFolder: _Display
		lineageTag: caa92cc5-a0b0-49ef-bd3d-3b67fb8f95fe

	measure 'Is Shop Overrun' = ```
			
			IF(
			    CALCULATE([Hours Quoted Remaining], 
			        FILTER('function hierarchy', 'function hierarchy'[Is Shop] = TRUE())
			    ) < 0,
			    TRUE(),
			    FALSE()
			)
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 7cc4703d-7d55-442b-b48f-fc3df8a73745

	measure 'Is Engineering Overrun' = ```
			
			IF(
			    CALCULATE([Hours Quoted Remaining], 
			        FILTER('function hierarchy', 'Function Hierarchy'[Is Engineering] = TRUE())
			    ) < 0,
			    TRUE(),
			    FALSE()
			)
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 49eaa5ce-ff3a-46b5-97cc-41059a55bbf5

