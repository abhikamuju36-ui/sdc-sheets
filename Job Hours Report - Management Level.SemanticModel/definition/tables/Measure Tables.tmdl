	measure 'ETC Monthly Process - Prior ETC' =
			
			VAR PriorMonthStart = EOMONTH(TODAY(), -2) + 1
			RETURN
			SUMX(
			    VALUES('Job'[Job Id]),
			    VAR JobStartDate = CALCULATE(MAX('Job'[Start Date]))
			    RETURN
			    IF(
			        NOT(ISBLANK(JobStartDate)) && JobStartDate >= PriorMonthStart,
			        [Hours Quoted],
			        [Hours Estimated to Complete]
			    )
			)
