	measure 'ETC Historical Hours Prior Month' = ```
			
			VAR CurrentPeriodKey = SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentYear = INT(CurrentPeriodKey / 100)
			VAR CurrentMonth = MOD(CurrentPeriodKey, 100)
			VAR PriorYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			VAR PriorMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PriorPeriodKey = PriorYear * 100 + PriorMonth
			RETURN
			SUMX(
			    VALUES(Job[Job Id]),
			    VAR CurrentJobId = Job[Job Id]
			    VAR JobStartDate = CALCULATE(MAX(Job[Start Date]), Job[Job Id] = CurrentJobId)
			    VAR JobStartYearMonth = 
			        IF(
			            NOT(ISBLANK(JobStartDate)),
			            YEAR(JobStartDate) * 100 + MONTH(JobStartDate),
			            BLANK()
			        )
			    VAR Result = 
			        IF(
			            JobStartYearMonth = PriorPeriodKey,
			            CALCULATE([Hours Quoted], Job[Job Id] = CurrentJobId),
			            CALCULATE(
			                SUM('Hours Estimated to Complete History'[Hours Estimated to Complete]),
			                Job[Job Id] = CurrentJobId,
			                REMOVEFILTERS('Estimated to Complete Period'),
			                'Hours Estimated to Complete History'[ETC Period Key] = PriorPeriodKey
			            )
			        )
			    RETURN Result
			)
			```
		formatString: #,0
		lineageTag: 889c7b3f-065b-4c2f-891a-ac8cece8d24b

		annotation PBI_FormatHint = {"isDecimal":true}

