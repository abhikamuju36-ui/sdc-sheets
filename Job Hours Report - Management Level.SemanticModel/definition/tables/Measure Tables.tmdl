	measure 'Hours Actual Billable Service Prior Month' =
			
			VAR CurrentPeriodKey = SELECTEDVALUE('Estimated to Complete Period'[ETC Period Key])
			VAR CurrentYear = INT(CurrentPeriodKey / 100)
			VAR CurrentMonth = MOD(CurrentPeriodKey, 100)
			VAR PriorYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			VAR PriorMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PriorPeriodKey = PriorYear * 100 + PriorMonth
			RETURN
			CALCULATE(
			    SUM('Hours Actual'[Hours Actual]),
			    REMOVEFILTERS('Date'),
			    REMOVEFILTERS('Job'),
			    ALLEXCEPT('Function Hierarchy', 'Function Hierarchy'[Billing Group]),
			    'Date'[Year Month Id] = PriorPeriodKey,
			    Employee[Employee Department] IN {"Controls Engineering","Machine Building","Machine Wiring","Mechanical Engineering","Manufacturing"},
			    FILTER(
			        ALL('Hours Actual'[Section-Function Code]),
			        LEFT('Hours Actual'[Section-Function Code], 2) = "80"
			    ),
			    'Job'[Is Active Job] = FALSE(),
			    NOT('Hours Actual'[Job Id] IN {"4000","1083"})
			)
		formatString: #,0
		lineageTag: bd6f22ae-cd6d-4ccd-8249-59402490f30a

