	measure 'Estimated to Complete As Of Date' = ```
			
			VAR ActiveBeginDate = 
			    CALCULATE(
			        MAX('Estimated to Complete Period'[ETC Begin Date]),
			        'Estimated to Complete Period'[ETC Is Active] = TRUE()
			    )
			VAR LastDayOfPriorMonth = EOMONTH(ActiveBeginDate, -1)
			RETURN
			LastDayOfPriorMonth
			```
		formatString: mmm dd, yyyy
		displayFolder: _Meta
		lineageTag: a5fb0fa1-bc65-4bd5-b06a-b2687c39f137

		annotation PBI_FormatHint = {"isCustom":true}

