	column 'Is Punch Valid' = ```
			
			VAR IsFuture = RELATED('Date'[Is Future Date])
			VAR JobId = RELATED(Job[Job Id])
			VAR JobStatus = RELATED(Job[Job Status])
			VAR JobCompleteDate = RELATED(Job[Complete Date])
			VAR SectionId = LEFT('Hours Actual'[Section-Function Code], 2)
			VAR IsValid = LOOKUPVALUE(
			    'Function Hierarchy'[Is Valid], 
			    'Function Hierarchy'[Section-Function Code], 'Hours Actual'[Section-Function Code],
			    'Function Hierarchy'[Is Total], FALSE()
			)
			
			RETURN
			SWITCH(
			    TRUE(),
			    IsFuture = TRUE(), FALSE(),
			    JobId = "4000", TRUE(),
			    JobId = "Not defined", FALSE(),
			    JobStatus = "Complete" && (SectionId IN {"70", "80", "90"}), TRUE(),
			    JobStatus = "Complete" && 'Hours Actual'[Date] > JobCompleteDate && NOT(SectionId IN {"70", "80", "90"}), FALSE(),
			    IF(
			        ISBLANK(IsValid), TRUE() //NEED TO INVESTIGATE, THERE SHOULD BE NO BLANKS
			        , IsValid)
			)
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 8e6f55c9-e10b-4672-93c9-d4aba901cd1c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Is Punch Valid Reason' = ```
			
			VAR IsFuture = RELATED('Date'[Is Future Date])
			VAR JobId = RELATED(Job[Job Id])
			VAR JobStatus = RELATED(Job[Job Status])
			VAR JobCompleteDate = RELATED(Job[Complete Date])
			VAR SectionId = LEFT('Hours Actual'[Section-Function Code], 2)
			VAR IsValid = 
			    IFERROR(
			        LOOKUPVALUE(
			            'Function Hierarchy'[Is Valid], 
			            'Function Hierarchy'[Section-Function Code], 'Hours Actual'[Section-Function Code],
			            'Function Hierarchy'[Is Total], FALSE()
			        ),
			        FALSE()
			    )
			
			RETURN
			SWITCH(
			    TRUE(),
			    IsFuture = TRUE(), "Future",
			    JobId = "4000", "Valid",
			    JobId = "Not defined", "Job Id Not Defined",
			    JobStatus = "Complete" && (SectionId IN {"70", "80", "90"}), "Valid",
			    JobStatus = "Complete" && 'Hours Actual'[Date] > JobCompleteDate && NOT(SectionId IN {"70", "80", "90"}),"Completed Job and Not Sections 70, 80, 90",
			    IF(
			        ISBLANK(IsValid), TRUE() //NEED TO INVESTIGATE, THERE SHOULD BE NO BLANKS
			        , IsValid) = FALSE(), "Section-Function Exception"
			    ,"Valid"
			)
			```
		dataType: string
		lineageTag: 93bd2274-c6bc-4586-9e4e-a4f200a463ed
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

