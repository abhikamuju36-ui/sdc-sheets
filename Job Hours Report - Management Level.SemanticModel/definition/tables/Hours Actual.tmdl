	column 'Is Hours Actual > 0.5' = 'Hours Actual'[Hours Actual] > 0.5
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b646949e-6e5e-461c-a9cb-c4eff001f1e2
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Hours Actual' = m
		mode: import
		queryGroup: Facts
		source = ```
				let
				    Source = Table.Combine({#"Hours Actual 20250131",#"Hours Actual 2025", #"Hours Actual YtD"}),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Job Id", type text}}),
				    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"Section Id", "Sub-Section Id"}}),
				    #"Added Custom" = Table.AddColumn(#"Renamed Columns", "Function Hierarchy Id", each [#"Sub-Section Id"]&"-"&[Function Id]),
				    #"Filtered Rows" = Table.SelectRows(#"Added Custom", each [Function Id] <> "417"),
				    //SPLIT 10-311 into 312 and 313 by creating 2 sub-tables and then recombining
				    // Filter out the 10-311 rows to keep separately
				    RowsToSplit = Table.SelectRows(#"Filtered Rows", each [Function Hierarchy Id] = "10-311"),
				    OtherRows = Table.SelectRows(#"Filtered Rows", each [Function Hierarchy Id] <> "10-311"),
				    
				    // Create first version of the rows to split (for 312) - 30%
				    FirstSplit = Table.TransformColumns(RowsToSplit, {
				        {"Function Hierarchy Id", each "10-312", type text},
				        {"Function Id", each "312", type text},
				        {"Hours Actual", each try if _ = null or _ = 0 then 0 else _ * 0.3 otherwise 0, type number}
				    }),
				    
				    // Create second version of the rows to split (for 313) - 70%
				    SecondSplit = Table.TransformColumns(RowsToSplit, {
				        {"Function Hierarchy Id", each "10-313", type text},
				        {"Function Id", each "313", type text},
				        {"Hours Actual", each try if _ = null or _ = 0 then 0 else _ * 0.7 otherwise 0, type number}
				    }),
				    
				    // Combine all three tables back together
				    CombinedTable = Table.Combine({OtherRows, FirstSplit, SecondSplit}),
				    #"Renamed Columns1" = Table.RenameColumns(CombinedTable,{{"Function Hierarchy Id", "Section-Function Code"}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Renamed Columns1",null,1,Replacer.ReplaceValue,{"Row Count"}),
				    #"Added Custom1" = Table.AddColumn(#"Replaced Value", "Job Section Function Code", each [Job Id]&"|"&[#"Section-Function Code"])
				in
				    #"Added Custom1"
				```

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

