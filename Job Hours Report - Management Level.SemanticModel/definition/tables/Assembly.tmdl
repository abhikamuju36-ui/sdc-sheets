	measure 'Line Assembly Part Quantity' = ```
			
			IF(
			    [Show Row In Hierarchy],
			    VAR CurrentLevel0 = VALUES(Assembly[Level0_Part])
			    VAR CurrentLevel1 = VALUES(Assembly[Level1_Part])
			    VAR CurrentLevel2 = VALUES(Assembly[Level2_Part])
			    VAR CurrentLevel3 = VALUES(Assembly[Level3_Part])
			    VAR CurrentLevel4 = VALUES(Assembly[Level4_Part])
			    VAR CurrentLevel5 = VALUES(Assembly[Level5_Part])
			    VAR CurrentLevel6 = VALUES(Assembly[Level6_Part])
			    VAR CurrentLevel7 = VALUES(Assembly[Level7_Part])
			    VAR CurrentLevel8 = VALUES(Assembly[Level8_Part])
			    VAR CurrentLevel9 = VALUES(Assembly[Level9_Part])
			    
			    VAR DeepestLevel = 
			        SWITCH(TRUE(),
			            ISINSCOPE(Assembly[Level9_Part]) && NOT ISBLANK(CurrentLevel9), 9,
			            ISINSCOPE(Assembly[Level8_Part]) && NOT ISBLANK(CurrentLevel8), 8,
			            ISINSCOPE(Assembly[Level7_Part]) && NOT ISBLANK(CurrentLevel7), 7,
			            ISINSCOPE(Assembly[Level6_Part]) && NOT ISBLANK(CurrentLevel6), 6,
			            ISINSCOPE(Assembly[Level5_Part]) && NOT ISBLANK(CurrentLevel5), 5,
			            ISINSCOPE(Assembly[Level4_Part]) && NOT ISBLANK(CurrentLevel4), 4,
			            ISINSCOPE(Assembly[Level3_Part]) && NOT ISBLANK(CurrentLevel3), 3,
			            ISINSCOPE(Assembly[Level2_Part]) && NOT ISBLANK(CurrentLevel2), 2,
			            ISINSCOPE(Assembly[Level1_Part]) && NOT ISBLANK(CurrentLevel1), 1,
			            ISINSCOPE(Assembly[Level0_Part]) && NOT ISBLANK(CurrentLevel0), 0,
			            -1
			        )
			    
			    RETURN
			        CALCULATE(
			            VALUES(Assembly[Hierarchical Quantity]),
			            Assembly[Level0_Part] = CurrentLevel0,
			            IF(DeepestLevel >= 1, Assembly[Level1_Part] = CurrentLevel1, ISBLANK(Assembly[Level1_Part])),
			            IF(DeepestLevel >= 2, Assembly[Level2_Part] = CurrentLevel2, ISBLANK(Assembly[Level2_Part])),
			            IF(DeepestLevel >= 3, Assembly[Level3_Part] = CurrentLevel3, ISBLANK(Assembly[Level3_Part])),
			            IF(DeepestLevel >= 4, Assembly[Level4_Part] = CurrentLevel4, ISBLANK(Assembly[Level4_Part])),
			            IF(DeepestLevel >= 5, Assembly[Level5_Part] = CurrentLevel5, ISBLANK(Assembly[Level5_Part])),
			            IF(DeepestLevel >= 6, Assembly[Level6_Part] = CurrentLevel6, ISBLANK(Assembly[Level6_Part])),
			            IF(DeepestLevel >= 7, Assembly[Level7_Part] = CurrentLevel7, ISBLANK(Assembly[Level7_Part])),
			            IF(DeepestLevel >= 8, Assembly[Level8_Part] = CurrentLevel8, ISBLANK(Assembly[Level8_Part])),
			            IF(DeepestLevel >= 9, Assembly[Level9_Part] = CurrentLevel9, ISBLANK(Assembly[Level9_Part])),
			            NOT ISBLANK(Assembly[Part Quantity])
			        ),
			    BLANK()
			)
			```
		formatString: 0
		lineageTag: 030cba19-4dc5-49f4-a4da-9879e03e97a4

	measure 'Line Assembly Part Cost' = ```
			
			IF(
			    [Show Row In Hierarchy],
			    VAR CurrentLevel0 = VALUES(Assembly[Level0_Part])
			    VAR CurrentLevel1 = VALUES(Assembly[Level1_Part])
			    VAR CurrentLevel2 = VALUES(Assembly[Level2_Part])
			    VAR CurrentLevel3 = VALUES(Assembly[Level3_Part])
			    VAR CurrentLevel4 = VALUES(Assembly[Level4_Part])
			    VAR CurrentLevel5 = VALUES(Assembly[Level5_Part])
			    VAR CurrentLevel6 = VALUES(Assembly[Level6_Part])
			    VAR CurrentLevel7 = VALUES(Assembly[Level7_Part])
			    VAR CurrentLevel8 = VALUES(Assembly[Level8_Part])
			    VAR CurrentLevel9 = VALUES(Assembly[Level9_Part])
			    
			    VAR DeepestLevel = 
			        SWITCH(TRUE(),
			            ISINSCOPE(Assembly[Level9_Part]) && NOT ISBLANK(CurrentLevel9), 9,
			            ISINSCOPE(Assembly[Level8_Part]) && NOT ISBLANK(CurrentLevel8), 8,
			            ISINSCOPE(Assembly[Level7_Part]) && NOT ISBLANK(CurrentLevel7), 7,
			            ISINSCOPE(Assembly[Level6_Part]) && NOT ISBLANK(CurrentLevel6), 6,
			            ISINSCOPE(Assembly[Level5_Part]) && NOT ISBLANK(CurrentLevel5), 5,
			            ISINSCOPE(Assembly[Level4_Part]) && NOT ISBLANK(CurrentLevel4), 4,
			            ISINSCOPE(Assembly[Level3_Part]) && NOT ISBLANK(CurrentLevel3), 3,
			            ISINSCOPE(Assembly[Level2_Part]) && NOT ISBLANK(CurrentLevel2), 2,
			            ISINSCOPE(Assembly[Level1_Part]) && NOT ISBLANK(CurrentLevel1), 1,
			            ISINSCOPE(Assembly[Level0_Part]) && NOT ISBLANK(CurrentLevel0), 0,
			            -1
			        )
			    
			    VAR HierQty = 
			        CALCULATE(
			            SUM(Assembly[Hierarchical Quantity]),
			            Assembly[Level0_Part] = CurrentLevel0,
			            IF(DeepestLevel >= 1, Assembly[Level1_Part] = CurrentLevel1, ISBLANK(Assembly[Level1_Part])),
			            IF(DeepestLevel >= 2, Assembly[Level2_Part] = CurrentLevel2, ISBLANK(Assembly[Level2_Part])),
			            IF(DeepestLevel >= 3, Assembly[Level3_Part] = CurrentLevel3, ISBLANK(Assembly[Level3_Part])),
			            IF(DeepestLevel >= 4, Assembly[Level4_Part] = CurrentLevel4, ISBLANK(Assembly[Level4_Part])),
			            IF(DeepestLevel >= 5, Assembly[Level5_Part] = CurrentLevel5, ISBLANK(Assembly[Level5_Part])),
			            IF(DeepestLevel >= 6, Assembly[Level6_Part] = CurrentLevel6, ISBLANK(Assembly[Level6_Part])),
			            IF(DeepestLevel >= 7, Assembly[Level7_Part] = CurrentLevel7, ISBLANK(Assembly[Level7_Part])),
			            IF(DeepestLevel >= 8, Assembly[Level8_Part] = CurrentLevel8, ISBLANK(Assembly[Level8_Part])),
			            IF(DeepestLevel >= 9, Assembly[Level9_Part] = CurrentLevel9, ISBLANK(Assembly[Level9_Part])),
			            NOT ISBLANK(Assembly[Part Quantity])
			        )
			    
			    VAR UnitCost = 
			        CALCULATE(
			            SUM(Assembly[Unit Cost]),
			            Assembly[Level0_Part] = CurrentLevel0,
			            IF(DeepestLevel >= 1, Assembly[Level1_Part] = CurrentLevel1, ISBLANK(Assembly[Level1_Part])),
			            IF(DeepestLevel >= 2, Assembly[Level2_Part] = CurrentLevel2, ISBLANK(Assembly[Level2_Part])),
			            IF(DeepestLevel >= 3, Assembly[Level3_Part] = CurrentLevel3, ISBLANK(Assembly[Level3_Part])),
			            IF(DeepestLevel >= 4, Assembly[Level4_Part] = CurrentLevel4, ISBLANK(Assembly[Level4_Part])),
			            IF(DeepestLevel >= 5, Assembly[Level5_Part] = CurrentLevel5, ISBLANK(Assembly[Level5_Part])),
			            IF(DeepestLevel >= 6, Assembly[Level6_Part] = CurrentLevel6, ISBLANK(Assembly[Level6_Part])),
			            IF(DeepestLevel >= 7, Assembly[Level7_Part] = CurrentLevel7, ISBLANK(Assembly[Level7_Part])),
			            IF(DeepestLevel >= 8, Assembly[Level8_Part] = CurrentLevel8, ISBLANK(Assembly[Level8_Part])),
			            IF(DeepestLevel >= 9, Assembly[Level9_Part] = CurrentLevel9, ISBLANK(Assembly[Level9_Part])),
			            NOT ISBLANK(Assembly[Part Quantity])
			        )
			    
			    RETURN HierQty * UnitCost,
			    BLANK()
			)
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: e73a953d-ada8-469c-a3fe-cc16d7c65ac7

	measure 'Assembly Total Part Cost' =
			
			IF(
			    [Show Row In Hierarchy],
			    CALCULATE(
			        SUMX(
			            FILTER(Assembly, NOT ISBLANK(Assembly[Part Quantity])),
			            Assembly[Hierarchical Quantity] * Assembly[Unit Cost]
			        )
			    ),
			    BLANK()
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 721682ad-e7e5-4369-a42f-61c37d69b6f8

	measure 'Assembly Total Part Quantity' =
			
			IF(
			    [Show Row In Hierarchy],
			    CALCULATE(
			        SUM(Assembly[Hierarchical Quantity]),
			        NOT ISBLANK(Assembly[Part Quantity])  // Only sum parts, not assemblies
			    ),
			    BLANK()
			)
		formatString: #,0
		lineageTag: 0488c77d-592e-4be2-82d0-d9ffbf01f6f6

	measure 'Assembly Count' =
			
			IF(
			    [Show Row In Hierarchy],
			    CALCULATE(
			        COUNTROWS(Assembly),
			        NOT ISBLANK(Assembly[Assembly Quantity])  // Only count assembly rows
			    ),
			    BLANK()
			)
		formatString: 0
		lineageTag: dcacea02-3db2-46fd-9f95-5bc3f6a96a07

