	partition Assembly = m
		mode: import
		queryGroup: Facts
		source =
				let
				    Source = Sql.Database("10.0.0.7:1433", "SDC", [Query="DECLARE @bitExplodeStandardAssemblies bit = 1#(lf)#(lf);WITH SpecList AS (#(lf)    SELECT S.ProjectID, S.SpecID#(lf)    FROM tblSpec S WITH (NOLOCK)#(lf)        INNER JOIN tlkpMachineTypes MT WITH (NOLOCK) ON S.MachineType = MT.MachineType#(lf)    WHERE MachineTypeSystemID <> 2#(lf)),#(lf)AllSpecsData AS (#(lf)    SELECT ERB.*#(lf)    FROM SpecList SL#(lf)        CROSS APPLY dbo.udfEngReportsBaseWithStandardAssemblyExplode(#(lf)            SL.ProjectID,  -- Changed from @intProjectID to SL.ProjectID#(lf)            SL.SpecID, #(lf)            NULL, #(lf)            @bitExplodeStandardAssemblies#(lf)        ) ERB#(lf)),#(lf)-- Add pricing information#(lf)BOMWithPricing AS (#(lf)    SELECT #(lf)        A.*,#(lf)        ISNULL(EIM.ItemLastCost, 0) AS UnitCost,#(lf)        ISNULL(EIM.ItemLastCost, 0) * A.ItemQty AS ExtendedCost,#(lf)        case when CategoryDescription = 'Assembly' then A.ItemQty else null end AS AssemblyQty,#(lf)        case when CategoryDescription != 'Assembly' then A.ItemQty else null end AS PartQty,#(lf)        PC.PurchasePrice,#(lf)        PC.TotalPurchased,#(lf)        PC.TotalInvoiced#(lf)    FROM AllSpecsData A#(lf)        LEFT JOIN tblEngItemMaster EIM WITH (NOLOCK) ON A.ChildID = EIM.ItemID#(lf)        LEFT JOIN (#(lf)            SELECT #(lf)                POD.ItemID,#(lf)                POD.ProjectID,#(lf)                POD.SpecID,#(lf)                SUM(POD.PurchaseQty) AS TotalPurchased,#(lf)                AVG(POD.PurchasePrice) AS PurchasePrice,#(lf)                SUM(ISNULL(INV.TotalInvoicedAmount, 0)) AS TotalInvoiced#(lf)            FROM tblPurchaseOrderDetails POD WITH(NOLOCK)#(lf)                LEFT JOIN (#(lf)                    SELECT #(lf)                        APDD.PurchaseDetailID,#(lf)                        SUM(APDocQty * APDocUnitPrice * (1 - APDocItemPctDisc) * APDocCurrRate) AS TotalInvoicedAmount#(lf)                    FROM tblAPDocumentDetails APDD WITH(NOLOCK)#(lf)                        INNER JOIN tblAPBatchDocument APBD WITH(NOLOCK) ON APBD.APDocID = APDD.APDocID#(lf)                    WHERE BatchEntryTypeID NOT IN (2, 3) AND APDD.PurchaseDetailID IS NOT NULL#(lf)                    GROUP BY APDD.PurchaseDetailID#(lf)                ) INV ON POD.PurchaseDetailID = INV.PurchaseDetailID#(lf)            GROUP BY POD.ItemID, POD.ProjectID, POD.SpecID#(lf)        ) PC ON A.ChildID = PC.ItemID AND A.ProjectID = PC.ProjectID AND A.SpecID = PC.SpecID  -- Added SpecID to join#(lf)),#(lf)-- Parse the hierarchy path into numbered rows WITH descriptions#(lf)ParsedPaths AS (#(lf)    SELECT #(lf)        B.*,#(lf)        CA.ItemNum,#(lf)        CA.PartAtLevel,#(lf)        CA.DescAtLevel#(lf)    FROM BOMWithPricing B#(lf)        CROSS APPLY (#(lf)            -- Parse the parent hierarchy AND add the child as the final level#(lf)            SELECT #(lf)                ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1 AS ItemNum,#(lf)                LTRIM(RTRIM(Split.a.value('.', 'NVARCHAR(500)'))) AS PartAtLevel,#(lf)                -- Get the description for each part in the hierarchy#(lf)                (SELECT TOP 1 EIM2.ItemDescription #(lf)                 FROM tblEngItemMaster EIM2 WITH (NOLOCK)#(lf)                 WHERE EIM2.ItemCompanyID = LTRIM(RTRIM(Split.a.value('.', 'NVARCHAR(500)')))) AS DescAtLevel#(lf)            FROM (#(lf)                -- Append the child part to the parent hierarchy path and escape XML special characters#(lf)                SELECT CAST('<X>' + #(lf)                    REPLACE(#(lf)                        REPLACE(#(lf)                            REPLACE(#(lf)                                REPLACE(#(lf)                                    REPLACE(B.PartNumberHierarchy + '\' + B.ItemCompanyID, '&', '&amp;'),#(lf)                                '<', '&lt;'),#(lf)                            '>', '&gt;'),#(lf)                        '""', '&quot;'),#(lf)                    '\', '</X><X>') + '</X>' AS XML) AS String#(lf)            ) AS A #(lf)            CROSS APPLY String.nodes('/X') AS Split(a)#(lf)            WHERE LTRIM(RTRIM(Split.a.value('.', 'NVARCHAR(500)'))) <> ''#(lf)        ) CA#(lf))#(lf)#(lf)-- Pivot the parsed paths into columns with part number + description#(lf)SELECT  #(lf)    CAST(ProjectID AS NVARCHAR(50)) AS ProjectID,#(lf)    CAST(SpecID AS NVARCHAR(50)) AS SpecID,#(lf)    -- Keys for parent-child hierarchy - use PartNumberHierarchy path to make unique#(lf)    -- Standardize by trimming slashes and adding them back consistently#(lf)    TRIM('\' FROM TRIM(PartNumberHierarchy + ItemCompanyID)) AS ItemKey,#(lf)    CASE #(lf)        WHEN Indent = 0 THEN TRIM('\' FROM TRIM(PItemCompanyID))  -- Point to root record#(lf)        ELSE TRIM('\' FROM TRIM(PartNumberHierarchy))#(lf)    END AS ParentKey,#(lf)    Indent+2 AS Level,  -- Add 2 since we're adding a root level#(lf)    LTRIM(RTRIM(#(lf)        REPLACE(#(lf)            REPLACE(#(lf)                REPLACE(PartNumberHierarchy + '\' + ItemCompanyID, '\\', '\'),#(lf)                '\\', '\'#(lf)            ),#(lf)            '\', ' > '#(lf)        )#(lf)    )) AS FullPath,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 0 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 1 THEN N'  ' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level0_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 1 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 2 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level1_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 2 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 3 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level2_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 3 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 4 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level3_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 4 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 5 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level4_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 5 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 6 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level5_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 6 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 7 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level6_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 7 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 8 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level7_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 8 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 9 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level8_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 9 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 10 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level9_Part,#(lf)    #(lf)    MAX(CASE WHEN ItemNum = 10 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 11 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level10_Part,#(lf)    #(lf)    -- Power BI Sort columns for each level#(lf)    MAX(CASE WHEN ItemNum = 0 THEN PartAtLevel END) AS Level0_Sort,#(lf)    MAX(CASE WHEN ItemNum = 1 THEN PartAtLevel END) AS Level1_Sort,#(lf)    MAX(CASE WHEN ItemNum = 2 THEN PartAtLevel END) AS Level2_Sort,#(lf)    MAX(CASE WHEN ItemNum = 3 THEN PartAtLevel END) AS Level3_Sort,#(lf)    MAX(CASE WHEN ItemNum = 4 THEN PartAtLevel END) AS Level4_Sort,#(lf)    MAX(CASE WHEN ItemNum = 5 THEN PartAtLevel END) AS Level5_Sort,#(lf)    MAX(CASE WHEN ItemNum = 6 THEN PartAtLevel END) AS Level6_Sort,#(lf)    MAX(CASE WHEN ItemNum = 7 THEN PartAtLevel END) AS Level7_Sort,#(lf)    MAX(CASE WHEN ItemNum = 8 THEN PartAtLevel END) AS Level8_Sort,#(lf)    MAX(CASE WHEN ItemNum = 9 THEN PartAtLevel END) AS Level9_Sort,#(lf)    MAX(CASE WHEN ItemNum = 10 THEN PartAtLevel END) AS Level10_Sort,#(lf)    #(lf)    REPLICATE('  ', Indent) + ItemCompanyID AS VisualHierarchy,#(lf)    ParentID,#(lf)    PItemCompanyID AS ParentPartNumber,#(lf)    PItemDescription AS ParentDescription,#(lf)    ChildID,#(lf)    ItemCompanyID AS ChildPartNumber,#(lf)    ItemDescription AS ChildDescription,#(lf)    REPLICATE('--', Indent) + '> ' + ItemCompanyID AS TreeView,#(lf)    CASE #(lf)        WHEN CategoryDescription = 'Assembly' THEN '1-' + ItemCompanyID#(lf)        ELSE '2-' + ItemCompanyID#(lf)    END AS PowerBISortOrder,#(lf)    AssemblyQty as [Assembly Quantity],#(lf)    PartQty as [Part Quantity],#(lf)    CASE #(lf)        WHEN CategoryDescription = 'Assembly' THEN AssemblyQty#(lf)        ELSE PartQty * HierarchicalQuantity #(lf)    END AS [Hierarchical Quantity],#(lf)    UnitCost AS [Unit Cost],#(lf)    ExtendedCost AS [Extended Cost],#(lf)    PurchasePrice AS [Purchase Price],#(lf)    TotalPurchased AS [Quantity Purchased],#(lf)    TotalInvoiced AS [Total Invoiced],#(lf)    CASE WHEN StandardAssemblyPart = 1 THEN 'Standard Assembly' ELSE 'Regular Part' END AS PartType,#(lf)    ItemCutLength,#(lf)    ItemLastRevision,#(lf)    UOMType,#(lf)    CategoryDescription,#(lf)    HierarchySortKey#(lf)    #(lf)FROM ParsedPaths#(lf)GROUP BY #(lf)    ProjectID,#(lf)    SpecID, Indent, ParentID, PItemCompanyID, PItemDescription, ChildID, #(lf)    ItemCompanyID, ItemDescription, PartNumberHierarchy, AssemblyQty, PartQty,#(lf)    HierarchicalQuantity, UnitCost, ExtendedCost, PurchasePrice, #(lf)    TotalPurchased, TotalInvoiced, StandardAssemblyPart, ItemCutLength,#(lf)    ItemLastRevision, UOMType, CategoryDescription, HierarchySortKey#(lf)#(lf)UNION ALL#(lf)#(lf)-- Create root records from the ParentID where ParentID != 0 at the top level#(lf)-- These are the actual root items that aren't appearing as children#(lf)SELECT DISTINCT#(lf)    CAST(ProjectID AS NVARCHAR(50)) AS ProjectID,#(lf)    CAST(SpecID AS NVARCHAR(50)) AS SpecID,#(lf)    TRIM('\' FROM TRIM(PItemCompanyID)) AS ItemKey,  -- Root trimmed of slashes#(lf)    CAST(NULL AS NVARCHAR(200)) AS ParentKey,#(lf)    1 AS Level,  -- Root is level 1#(lf)    PItemCompanyID AS FullPath,#(lf)    (CASE WHEN ItemNum = 0 THEN #(lf)        CASE WHEN CategoryDescription != 'Assembly' AND Indent+2 = 1 THEN N'' ELSE N'⬢ ' END + #(lf)        PartAtLevel + ' - ' + ISNULL(DescAtLevel, '') #(lf)    END) AS Level0_Part,#(lf)    NULL AS Level1_Part,#(lf)    NULL AS Level2_Part,#(lf)    NULL AS Level3_Part,#(lf)    NULL AS Level4_Part,#(lf)    NULL AS Level5_Part,#(lf)    NULL AS Level6_Part,#(lf)    NULL AS Level7_Part,#(lf)    NULL AS Level8_Part,#(lf)    NULL AS Level9_Part,#(lf)    NULL AS Level10_Part,#(lf)    PItemCompanyID AS Level0_Sort,#(lf)    NULL AS Level1_Sort,#(lf)    NULL AS Level2_Sort,#(lf)    NULL AS Level3_Sort,#(lf)    NULL AS Level4_Sort,#(lf)    NULL AS Level5_Sort,#(lf)    NULL AS Level6_Sort,#(lf)    NULL AS Level7_Sort,#(lf)    NULL AS Level8_Sort,#(lf)    NULL AS Level9_Sort,#(lf)    NULL AS Level10_Sort,#(lf)    PItemCompanyID AS VisualHierarchy,#(lf)    ParentID,#(lf)    NULL AS ParentPartNumber,#(lf)    NULL AS ParentDescription,#(lf)    ParentID AS ChildID,#(lf)    PItemCompanyID AS ChildPartNumber,#(lf)    PItemDescription AS ChildDescription,#(lf)    PItemCompanyID AS TreeView,#(lf)    '0-' + PItemCompanyID AS PowerBISortOrder,#(lf)    NULL AS [Assembly Quantity],#(lf)    NULL AS [Part Quantity],#(lf)    NULL AS [Hierarchical Quantity],#(lf)    0.0 AS [Unit Cost],#(lf)    0.0 AS [Extended Cost],#(lf)    NULL AS [Purchase Price],#(lf)    NULL AS [Quantity Purchased],#(lf)    NULL AS [Total Invoiced],#(lf)    'Root' AS PartType,#(lf)    NULL AS ItemCutLength,#(lf)    NULL AS ItemLastRevision,#(lf)    NULL AS UOMType,#(lf)    'Root' AS CategoryDescription,#(lf)    '' AS HierarchySortKey#(lf)FROM ParsedPaths#(lf)WHERE Indent = 0 AND ParentID <> 0"])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

