	measure 'Show Row In Hierarchy' =
			
			SWITCH(
			    TRUE(),
			    AND(ISINSCOPE(Assembly[Level0_Part]), ISBLANK(VALUES(Assembly[Level0_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level1_Part]), ISBLANK(VALUES(Assembly[Level1_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level2_Part]), ISBLANK(VALUES(Assembly[Level2_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level3_Part]), ISBLANK(VALUES(Assembly[Level3_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level4_Part]), ISBLANK(VALUES(Assembly[Level4_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level5_Part]), ISBLANK(VALUES(Assembly[Level5_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level6_Part]), ISBLANK(VALUES(Assembly[Level6_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level7_Part]), ISBLANK(VALUES(Assembly[Level7_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level8_Part]), ISBLANK(VALUES(Assembly[Level8_Part]))), FALSE(),
			    AND(ISINSCOPE(Assembly[Level9_Part]), ISBLANK(VALUES(Assembly[Level9_Part]))), FALSE(),
			    TRUE()
			)
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: dc37c468-0207-4453-a579-874dba3a9c37

	measure 'Level Count' =
			
			IF(
			    [Show Row In Hierarchy],
			    DISTINCTCOUNT(Assembly[Level]),
			    BLANK()
			)
		formatString: 0
		lineageTag: 0b1c4d9f-8b35-40ac-b6d1-f7876330212a

	measure 'Line Assembly Quantity' = ```
			
			IF(
			    [Show Row In Hierarchy],
			    VAR CurrentLevel0 = SELECTEDVALUE(Assembly[Level0_Part])
			    VAR CurrentLevel1 = SELECTEDVALUE(Assembly[Level1_Part])
			    VAR CurrentLevel2 = SELECTEDVALUE(Assembly[Level2_Part])
			    VAR CurrentLevel3 = SELECTEDVALUE(Assembly[Level3_Part])
			    VAR CurrentLevel4 = SELECTEDVALUE(Assembly[Level4_Part])
			    VAR CurrentLevel5 = SELECTEDVALUE(Assembly[Level5_Part])
			    VAR CurrentLevel6 = SELECTEDVALUE(Assembly[Level6_Part])
			    VAR CurrentLevel7 = SELECTEDVALUE(Assembly[Level7_Part])
			    VAR CurrentLevel8 = SELECTEDVALUE(Assembly[Level8_Part])
			    VAR CurrentLevel9 = SELECTEDVALUE(Assembly[Level9_Part])
			    
			    VAR DeepestLevel = 
			        SWITCH(TRUE(),
			            ISINSCOPE(Assembly[Level9_Part]) && NOT ISBLANK(CurrentLevel9), 9,
			            ISINSCOPE(Assembly[Level8_Part]) && NOT ISBLANK(CurrentLevel8), 8,
			            ISINSCOPE(Assembly[Level7_Part]) && NOT ISBLANK(CurrentLevel7), 7,
			            ISINSCOPE(Assembly[Level6_Part]) && NOT ISBLANK(CurrentLevel6), 6,
			            ISINSCOPE(Assembly[Level5_Part]) && NOT ISBLANK(CurrentLevel5), 5,
			            ISINSCOPE(Assembly[Level4_Part]) && NOT ISBLANK(CurrentLevel4), 4,
			            ISINSCOPE(Assembly[Level3_Part]) && NOT ISBLANK(CurrentLevel3), 3,
			            ISINSCOPE(Assembly[Level2_Part]) && NOT ISBLANK(CurrentLevel2), 2,
			            ISINSCOPE(Assembly[Level1_Part]) && NOT ISBLANK(CurrentLevel1), 1,
			            ISINSCOPE(Assembly[Level0_Part]) && NOT ISBLANK(CurrentLevel0), 0,
			            -1
			        )
			    
			    RETURN
			        CALCULATE(
			            SUM(Assembly[Assembly Quantity]),
			            Assembly[Level0_Part] = CurrentLevel0,
			            IF(DeepestLevel >= 1, Assembly[Level1_Part] = CurrentLevel1, ISBLANK(Assembly[Level1_Part])),
			            IF(DeepestLevel >= 2, Assembly[Level2_Part] = CurrentLevel2, ISBLANK(Assembly[Level2_Part])),
			            IF(DeepestLevel >= 3, Assembly[Level3_Part] = CurrentLevel3, ISBLANK(Assembly[Level3_Part])),
			            IF(DeepestLevel >= 4, Assembly[Level4_Part] = CurrentLevel4, ISBLANK(Assembly[Level4_Part])),
			            IF(DeepestLevel >= 5, Assembly[Level5_Part] = CurrentLevel5, ISBLANK(Assembly[Level5_Part])),
			            IF(DeepestLevel >= 6, Assembly[Level6_Part] = CurrentLevel6, ISBLANK(Assembly[Level6_Part])),
			            IF(DeepestLevel >= 7, Assembly[Level7_Part] = CurrentLevel7, ISBLANK(Assembly[Level7_Part])),
			            IF(DeepestLevel >= 8, Assembly[Level8_Part] = CurrentLevel8, ISBLANK(Assembly[Level8_Part])),
			            IF(DeepestLevel >= 9, Assembly[Level9_Part] = CurrentLevel9, ISBLANK(Assembly[Level9_Part]))
			        ),
			    BLANK()
			)
			```
		formatString: 0
		lineageTag: c25dc966-b02b-4de6-9127-1dabfa4e3492

	measure 'Min Level' = ```
			
