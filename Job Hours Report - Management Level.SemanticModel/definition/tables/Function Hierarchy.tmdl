	partition 'Function Hierarchy' = m
		mode: import
		queryGroup: Dimensions
		source = ```
				let
				    Source = Table.Combine({#"Function Hierarchy Prep", #"Function Hierarchy Total"}),
				    #"Replaced Value" = Table.ReplaceValue(Source,null,false,Replacer.ReplaceValue,{"Is Total"}),
				    
				    // Modified merge to exclude order columns
				    #"Merged Queries" = Table.NestedJoin(#"Replaced Value", {"Function Id"}, #"Function Department Import", {"Function Id"}, "Function Department Import.1", JoinKind.LeftOuter),
				    #"Expanded Function Department Import.1" = Table.ExpandTableColumn(#"Merged Queries", "Function Department Import.1", {"Function Department", "Function", "Function Department Order"}, {"Function Department", "Function.1", "Function Department Order"}),
				    
				    // Modified column renaming - rename first so we can work with correct column names
				    #"Renamed Columns" = Table.RenameColumns(#"Expanded Function Department Import.1",{
				        {"Function Name", "Section Function Name"}, 
				        {"Function Id", "Hierarchy Function Id"}, 
				        {"Function.1", "Function Name"}, 
				        {"Function Department", "Function Department Name"}, 
				        {"Function Group", "Section Function Group"}
				    }),
				    
				    #"Renamed Columns1" = Table.RenameColumns(#"Renamed Columns",{
				        {"Hierarchy Function Id", "Function Id"}, 
				        {"Function Hierarchy Id", "Section-Function Code"}
				    }),
				    
				    // Get unique values maintaining the order of first appearance
				    #"Added Index" = Table.AddIndexColumn(#"Renamed Columns1", "OriginalOrder", 0, 1),
				    
				    // Get first index for each distinct Section Function Name
				    #"Grouped Rows" = Table.Group(#"Added Index", {"Section Function Name"}, {
				        {"MinIndex", each List.Min([OriginalOrder]), type number}
				    }),
				    #"Sorted Rows" = Table.Sort(#"Grouped Rows",{{"MinIndex", Order.Ascending}}),
				    #"Added Rank" = Table.AddIndexColumn(#"Sorted Rows", "Section Function Order", 1, 1),
				    #"Removed Columns" = Table.RemoveColumns(#"Added Rank",{"MinIndex"}),
				    
				    // Create distinct lists with order for Section Name and Section Function Group
				    DistinctSections = Table.Group(#"Added Index", {"Section Name"}, {
				        {"MinIndex", each List.Min([OriginalOrder]), type number}
				    }),
				    SortedSections = Table.Sort(DistinctSections,{{"MinIndex", Order.Ascending}}),
				    SectionOrderTable = Table.AddIndexColumn(SortedSections, "Section Order", 1, 1),
				    #"Removed MinIndex" = Table.RemoveColumns(SectionOrderTable,{"MinIndex"}),
				    
				    DistinctGroups = Table.Group(#"Added Index", {"Section Function Group"}, {
				        {"MinIndex", each List.Min([OriginalOrder]), type number}
				    }),
				    SortedGroups = Table.Sort(DistinctGroups,{{"MinIndex", Order.Ascending}}),
				    GroupOrderTable = Table.AddIndexColumn(SortedGroups, "Section Function Group Order", 1, 1),
				    
				    // New step: Adjust the Shop order to be Engineering order + 0.1
				    #"Find Shop and Engineering" = Table.AddColumn(GroupOrderTable, "IsShop", each [Section Function Group] = "Shop"),
				    #"Find Engineering" = Table.AddColumn(#"Find Shop and Engineering", "IsEngineering", each [Section Function Group] = "Engineering"),
				    
				    // Get the Engineering order value (or default if not found)
				    EngineeringRows = Table.SelectRows(#"Find Engineering", each [IsEngineering] = true),
				    EngineeringOrder = if Table.RowCount(EngineeringRows) > 0 then EngineeringRows{0}[Section Function Group Order] else 6,
				    
				    // Adjust Shop's order to be just after Engineering
				    #"Adjusted Shop Order" = Table.ReplaceValue(
				        #"Find Engineering", 
				        each [Section Function Group Order], 
				        each if [IsShop] = true then EngineeringOrder + 0.1 else [Section Function Group Order],
				        Replacer.ReplaceValue,
				        {"Section Function Group Order"}
				    ),
				    
				    // Cleanup temp columns
				    #"Removed Helper Columns" = Table.RemoveColumns(#"Adjusted Shop Order", {"MinIndex", "IsShop", "IsEngineering"}),
				    
				    // Merge these back to the original table (without the OriginalOrder column)
				    #"Removed OriginalOrder" = Table.RemoveColumns(#"Renamed Columns1", {"OriginalOrder"}, MissingField.Ignore),
				    
				    MergedWithSectionFunctionOrder = Table.NestedJoin(#"Removed OriginalOrder", {"Section Function Name"}, #"Removed Columns", {"Section Function Name"}, "SectionFunctionOrderTable", JoinKind.LeftOuter),
				    ExpandedSectionFunctionOrder = Table.ExpandTableColumn(MergedWithSectionFunctionOrder, "SectionFunctionOrderTable", {"Section Function Order"}, {"Section Function Order"}),
				    
				    MergedWithSectionOrder = Table.NestedJoin(ExpandedSectionFunctionOrder, {"Section Name"}, #"Removed MinIndex", {"Section Name"}, "SectionOrderTable", JoinKind.LeftOuter),
				    ExpandedSectionOrder = Table.ExpandTableColumn(MergedWithSectionOrder, "SectionOrderTable", {"Section Order"}, {"Section Order"}),
				    
				    MergedWithGroupOrder = Table.NestedJoin(ExpandedSectionOrder, {"Section Function Group"}, #"Removed Helper Columns", {"Section Function Group"}, "GroupOrderTable", JoinKind.LeftOuter),
				    Result = Table.ExpandTableColumn(MergedWithGroupOrder, "GroupOrderTable", {"Section Function Group Order"}, {"Section Function Group Order"})
				in
				    Result
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

