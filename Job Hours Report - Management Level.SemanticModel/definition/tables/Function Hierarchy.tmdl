	column 'Section Function Name Dynamic' =
			
			IF(
			    'Function Hierarchy'[Section Function Name] = "Use Employee Department",
			    SWITCH(
			        CALCULATE(
			            FIRSTNONBLANK(Employee[Employee Department], 1),
			            RELATEDTABLE('Hours Actual')
			        ),
			        "Mechanical Engineering", "ME",
			        "Controls Engineering", "CE",
			        "Invalid"
			    ),
			    'Function Hierarchy'[Section Function Name]
			)
		lineageTag: 20bc78b2-71b3-462c-9da1-7ee15df4642b
		summarizeBy: none
		sortByColumn: 'Section Function Name Dynamic Order'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'Section Function Name Dynamic Order' =
			
			IF(
			    'Function Hierarchy'[Section Function Name] = "Use Employee Department",
			    SWITCH(
			        CALCULATE(
			            FIRSTNONBLANK(Employee[Employee Department], 1),
			            RELATEDTABLE('Hours Actual')
			        ),
			        "Mechanical Engineering", 13.00,
			        "Controls Engineering", 14.00,
			        16.00  // Invalid - use a new number
			    ),
			    'Function Hierarchy'[Section Function Order]
			)
		lineageTag: 33314e4f-3d8d-469e-a829-52dc086e2f03
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	hierarchy 'Function Department Hierarchy'
